# ==============================================================================
# AI Property Analyzer & Valuation — Environment Variables
# Copia questo file in .env e sostituisci i valori con i tuoi.
# ==============================================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# --- Moonshot AI (Kimi) ---
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k

# --- NVIDIA Build ---
# Ottieni la tua API key gratuita su https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-4-maverick-17b-128e-instruct

# --- Applicazione ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Playwright ---
PLAYWRIGHT_TIMEOUT=30000       # Timeout in ms per le operazioni del browser
PLAYWRIGHT_HEADLESS=true       # true = headless, false = mostra il browser (debug)

# --- Anti-Bot Proxy ---
# Registrati su https://www.scrapingbee.com e incolla la chiave qui per bypassare i blocchi anti-bot
SCRAPINGBEE_API_KEY=your-scrapingbee-key-here

# --- OMI ---
# Percorso al file CSV con i dati OMI. Lascia il default per usare il campione.
OMI_CSV_PATH=app/data/omi_sample.csv
